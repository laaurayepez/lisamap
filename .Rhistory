)
# ==============================================================================
# MAPA 1: Perímetro (Capas: 'HS_lisa')
# ==============================================================================
map1 <- read_sf(gpklink, layer = "HS_lisa")
map1$HS_lisa[is.na(map1$HS_lisa) | map1$HS_lisa == ""] <- "0"
map1gg <- ggplot() +
theme_void() +
geom_sf(data = map1, aes(fill = as.character(HS_lisa)), color = "#666666", size = 0.1) +
scale_fill_manual(values = lisa_colores, name = "LISA Perímetro", drop = FALSE)
saveRDS(map1gg, file = 'map_HS_lisa_oficial.rds')
# ==============================================================================
# MAPA 2: Rook (Capas: 'HS_lisa_rook')
# ==============================================================================
map2 <- read_sf(gpklink, layer = "HS_lisa_rook")
map2$HS_lisa_rook[is.na(map2$HS_lisa_rook) | map2$HS_lisa_rook == ""] <- "0"
map2gg <- ggplot() +
theme_void() +
geom_sf(data = map2, aes(fill = as.character(HS_lisa_rook)), color = "#666666", size = 0.1) +
scale_fill_manual(values = lisa_colores, name = "LISA Rook", drop = FALSE)
saveRDS(map2gg, file = 'map_HS_lisa_rook_oficial.rds')
# ==============================================================================
# MAPA 3: Queen (Capas: 'HS_lisa_queen')
# ==============================================================================
map3 <- read_sf(gpklink, layer = "HS_lisa_queen")
map3$HS_lisa_queen[is.na(map3$HS_lisa_queen) | map3$HS_lisa_queen == ""] <- "0"
map3gg <- ggplot() +
theme_void() +
geom_sf(data = map3, aes(fill = as.character(HS_lisa_queen)), color = "#666666", size = 0.1) +
scale_fill_manual(values = lisa_colores, name = "LISA Queen", drop = FALSE)
saveRDS(map3gg, file = 'map_HS_lisa_queen_oficial.rds')
