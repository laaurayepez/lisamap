"1"           = "#d7191c",  # Cuadrante 1: High-High (HotSpot - Rojo)
"3"           = "#2c7bb6",  # Cuadrante 3: Low-Low (ColdSpot - Azul)
"4"           = "#fdae61",  # Cuadrante 4: High-Low (HotOutlier - Naranja)
"2"           = "#abd9e9",  # Cuadrante 2: Low-High (ColdOutlier - Azul Claro)
"0"           = "#eeeeee"   # No significativo (Gris)
)
